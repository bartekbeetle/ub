# === BAZA DANYCH ===
# Produkcja (Railway Postgres): postgres://user:pass@host:5432/db
# Dev: zostaw puste -> aplikacja użyje wbudowanej bazy PGlite (plik ./.pglite)
DATABASE_URL=

# === APLIKACJA ===
# Publiczny URL (canonical, sitemap, OG). Bez trailing slasha.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Sekret do podpisywania sesji (min. 32 znaki, wygeneruj: openssl rand -hex 32)
SESSION_SECRET=

# === KONTO ADMINA (seed) ===
ADMIN_EMAIL=biuro@uniwersytetbeauty.pl
ADMIN_INITIAL_PASSWORD=

# === EMAIL (opcjonalne — brak = maile lądują w kolejce w DB) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Uniwersytet Beauty <biuro@uniwersytetbeauty.pl>"

# === ANALITYKA (opcjonalne — brak = skrypty się nie ładują) ===
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA4_ID=
